# Kopiere diese Datei nach .env und passe die Werte an.
# Die .env-Datei wird von der Anwendung automatisch geladen (nur lokal – ignoriert in CF).

# Pflichtfeld: AES-256-GCM-Schlüssel für Token- und Passwort-Verschlüsselung
TOKEN_ENCRYPTION_KEY=change-me-32-chars-minimum-secret!

# Backup Manager (Staging / lokale Zielumgebung)
MANAGER_LOCAL_URL=https://backup-manager-staging.example.com
AGENT_LOCAL_URL=https://backup-agent-staging.example.com
AGENT_LOCAL_USER=admin
AGENT_LOCAL_PASS=admin

# CloudFoundry Service Account (für Token-Abruf)
UAA_LOCAL_ENDPOINT=https://uaa.sys-staging.example.com
CF_API_LOCAL_ENDPOINT=https://api.sys-staging.example.com
SA_LOCAL_USERNAME=backup-monitor-sa
SA_LOCAL_PASSWORD=change-me

# Service-Instanz
LOCAL_INSTANCE_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
